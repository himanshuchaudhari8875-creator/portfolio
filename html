<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PDF Viewer</title>
    <style>
        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            width: 100%;
            overflow: hidden; /* Prevents scrolling */
        }
        .pdf-container {
            width: 100vw;
            height: 100vh;
        }
    </style>
</head>
<body>
    <!-- REPLACE 'my-document.pdf' WITH YOUR ACTUAL FILE NAME -->
    <embed src="my-document.pdf" type="application/pdf" class="pdf-container">
    
    <!-- Fallback for browsers that don't support PDF viewing -->
    <div style="text-align:center; padding:20px;">
        <p>Your browser does not support viewing PDF files directly.</p>
        <a href="">Download the PDF instead</a>
    </div>
</body>
</html>
